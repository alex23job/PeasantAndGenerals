  m_Text: "\u0421\u043E\u0431\u0438\u0440\u0430\u0439\u0442\u0435 \u0444\u0440\u0443\u043A\u0442\u044B.
    \u041A\u043B\u0438\u043A\u0430\u0439\u0442\u0435 \u043F\u043E \u0434\u0435\u0440\u0435\u0432\u044C\u044F\u043C
    \u043C\u044B\u0448\u043A\u043E\u0439, \u043D\u043E \u043F\u043E\u043C\u043D\u0438\u0442\u0435
    \u0447\u0438\u0441\u043B\u043E \u043A\u043B\u0438\u043A\u043E\u0432 \u0438 \u0432\u0440\u0435\u043C\u044F
