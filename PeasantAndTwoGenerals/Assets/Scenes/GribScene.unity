    m_LineSpacing: 1
  m_Text: "\u0425\u043E\u0434\u0438\u0442\u0435 \u043F\u043E \u043B\u0435\u0441\u0443
    \u0438 \u0441\u043E\u0431\u0438\u0440\u0430\u0439\u0442\u0435 \u0433\u0440\u0438\u0431\u044B.
    \u0415\u0441\u043B\u0438 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0435, \u0447\u0442\u043E
    \u043D\u0430\u0439\u0434\u0435\u043D\u043D\u044B\u0439 \u0433\u0440\u0438\u0431
    \u0441\u044A\u0435\u0434\u043E\u0431\u043D\u044B\u0439, \u0442\u043E \u0437\u0430\u0431\u0438\u0440\u0430\u0439\u0442\u0435
    \u0435\u0433\u043E \u0432 \u043A\u043E\u0440\u0437\u0438\u043D\u043A\u0443. "
